{
  "default_rule": "default.md",
  "path_rule_map": {
    "**/*.properties": "properties.md",
    "**/*{mapper,dao}*.xml": "mapper_dao_xml.md",
    "**/pom.xml": "pom_xml.md",
    "**/build.gradle": "build_gradle.md",
    "**/package.json": "package_json.md",
    "**/*.json": "json.md",
    "**/*.{yaml,yml}": "yaml.md",
    "**/*.java": "java.md",
    "**/*.{ts,js,tsx,jsx}": "ts_js_tsx_jsx.md",
    "**/*.{kt}": "kotlin.md",
    "**/*.{cpp,cc,hpp}": "cpp.md",
    "**/*.c": "c.md"
  }
}
